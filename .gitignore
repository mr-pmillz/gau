# Created by .ignore support plugin (hsz.mobi)
### Go template
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/
.DS_Store
.idea
dist
bin/
# Ignore coverage *output* (.out files, gotest logs) but keep the
# directory itself tracked via coverage/.gitkeep so CI runs and local
# tooling can write into a guaranteed-existing path.
coverage/*
!coverage/.gitkeep
